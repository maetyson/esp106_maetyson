plot(bluew, "ind_ident", col= sample(rainbow(bluew_ind)), add=TRUE, cex = 0.5 ,legend = FALSE)
#'subset' data into spat vectors
whale_00825 <- bluew[bluew$ind_ident == "2008CA-Bmu-00825",]
whale_10821 <- bluew[bluew$ind_ident == "2005CA-Bmu-10821",]
